# Business Brain — Environment Variables
# Copy to .env and fill in real values before running locally.
# Never commit .env to version control.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bbuser:bbpassword@localhost:5432/businessbrain
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=businessbrain
DATABASE_USER=bbuser
DATABASE_PASSWORD=bbpassword

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── Workers ─────────────────────────────────────────────────────────────────
WORKER_HEALTH_PORT=3001
SCHEDULER=true

# ─── Auth (RS256) ────────────────────────────────────────────────────────────
# RS256 PEM keys, \n-escaped onto a single line (env_file-safe; the app reconstitutes
# the newlines at ingestion). Generate a dev keypair, then escape each to one line:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   awk 'BEGIN{ORS="\\n"}1' private.pem   # → JWT_PRIVATE_KEY value (do the same for public.pem)
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_BASE64_PKCS8_PRIVATE_KEY_BODY\n-----END PRIVATE KEY-----\n
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_BASE64_SPKI_PUBLIC_KEY_BODY\n-----END PUBLIC KEY-----\n

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_REAL_KEY

# ─── LLM Model Selection ─────────────────────────────────────────────────────
LLM_STRONG_MODEL=claude-sonnet-4-6
LLM_MEDIUM_MODEL=claude-haiku-4-5

# ─── Email — magic-link delivery (Resend) ────────────────────────────────────
# Production (NODE_ENV=production) sends via Resend and FAILS FAST at startup if any of these is
# missing/invalid. Dev/test logs the labeled dev link instead (no send) — these can stay blank locally.
RESEND_API_KEY=re_REPLACE_WITH_REAL_KEY
EMAIL_FROM=Business Brain <access@auth.getbusinessbrain.com>
# The PUBLIC origin that serves /api/* — becomes the magic-link verify URL. MUST be https and not
# localhost in production (a localhost link in a real email is a dead letter; startup rejects it).
APP_BASE_URL=https://getbusinessbrain.com
# The post-verify redirect target (defaults to '/'). Distinct from APP_BASE_URL in dev (api :3000 vs
# web :8090); the same public origin in production.
WEB_BASE_URL=/

# ─── Encryption ──────────────────────────────────────────────────────────────
# 32-byte (64 hex chars) AES-256-GCM field encryption key
# Generate: openssl rand -hex 32
KMS_KEY_ID=REPLACE_WITH_64_CHAR_HEX_KEY

# ─── Telemetry ───────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=bb-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=info

# ─── Secrets Manager (production) ────────────────────────────────────────────
# AWS_REGION=eu-west-1
# AWS_SECRET_NAME=businessbrain/production
